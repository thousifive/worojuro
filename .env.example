# ─────────────────────────────────────────────────────────────────────────────
# Worojuro — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...          # safe to expose client-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...               # NEVER expose client-side

# Supabase connection string for Drizzle migrations
# Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Ollama (local AI — active now) ───────────────────────────────────────────
# Install: https://ollama.com/download
# Pull models: ollama pull llama3.2 && ollama pull nomic-embed-text
# Default: runs on localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
# Embedding dimensions must match the model:
#   nomic-embed-text → 768  (current)
#   text-embedding-3-small → 1536  (needs migration when switching)
EMBEDDING_DIMENSIONS=768

# ── Anthropic (boilerplate — add key when available) ──────────────────────────
# https://console.anthropic.com/settings/keys
# To activate: update server/ai/client.ts to use the Anthropic block
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── OpenAI (boilerplate — add key when available) ─────────────────────────────
# https://platform.openai.com/api-keys
# To activate: update server/ai/client.ts to use the OpenAI block
# Also run migration: ALTER TABLE jobs/resumes ALTER COLUMN embedding TYPE vector(1536)
# OPENAI_API_KEY=sk-proj-...

# ── Resend ────────────────────────────────────────────────────────────────────
# https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_...
# Must be a verified domain or resend.dev subdomain
RESEND_FROM_EMAIL=digest@yourdomain.com

# ── Cron security ─────────────────────────────────────────────────────────────
# Vercel injects this as Authorization: Bearer <secret> on cron invocations.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-output-of-openssl-rand-hex-32

# ── Adzuna (optional — 250 req/day free) ──────────────────────────────────────
# https://developer.adzuna.com/admin/applications
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key

# ── App URL ───────────────────────────────────────────────────────────────────
# Used in email links and for local cron testing
NEXT_PUBLIC_APP_URL=http://localhost:3000
